{
  "name": "@bambushu/ksa-data",
  "version": "1.1.12",
  "description": "Shared Dutch KSA-licensed iGaming market data",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npx tsx scripts/verify-bonuses.ts",
    "verify:promos": "npx tsx scripts/verify-promotions.ts",
    "daily-verify": "npx tsx scripts/daily-verify.ts",
    "daily-verify:dry": "npx tsx scripts/daily-verify.ts --dry-run"
  },
  "dependencies": {
    "@bambushu/casino-guard": "^1.1.0",
    "zod": "^3.23.8"
  },
  "files": [
    "dist",
    "logos",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
